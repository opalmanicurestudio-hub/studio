rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(tenantId) {
      return isSignedIn() && (
        request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.userId ||
        exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid)).data.role == 'owner'
      );
    }

    function isStaff(tenantId) {
      return isSignedIn() && (
        isOwner(tenantId) ||
        exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid))
      );
    }

    // --- Tenant Root ---
    match /tenants/{tenantId} {
      allow get: if true;
      allow list: if isSignedIn(); // Allow discovery of owned tenants
      allow update: if isOwner(tenantId);
    }

    // --- Public Whitelist for Portal/Check-in ---
    match /tenants/{tenantId}/services/{serviceId} {
      allow read: if true;
    }
    match /tenants/{tenantId}/staff/{staffId} {
      allow get: if true;
      allow read, write: if isStaff(tenantId);
    }
    match /tenants/{tenantId}/consentForms/{formId} {
      allow read: if true;
    }
    match /tenants/{tenantId}/scheduleProfiles/{profileId} {
      allow read: if true;
    }
    match /tenants/{tenantId}/inventory/{itemId} {
      allow list, get: if true; // Critical for concierge menu
      allow write: if isStaff(tenantId);
    }

    // --- Concierge Logic ---
    match /tenants/{tenantId}/refreshmentRequests/{requestId} {
      allow create: if true; 
      allow get: if true;
      allow list, update: if isStaff(tenantId);
    }

    // --- Check-in & Public Tokens ---
    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow update: if true;
    }

    match /tenants/{tenantId}/notifications/{notificationId} {
      allow create: if true;
      allow read, write: if isStaff(tenantId);
    }

    match /tenants/{tenantId}/appointments/{appointmentId} {
      allow get: if true;
      allow read, write: if isStaff(tenantId);
    }

    match /tenants/{tenantId}/clients/{clientId} {
      allow get: if true;
      allow create: if true;
      allow read, write: if isStaff(tenantId);
    }

    // --- Master Admin Access ---
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isStaff(tenantId);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /staffDirectory/{userId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}