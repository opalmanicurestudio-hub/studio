rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Identity Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Universal Owner Override.
     * Grants Jessica Marshall (Technical Owner) immediate master authority.
     */
    function isOwner(tenantId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.userId == request.auth.uid
      );
    }

    /**
     * @description Master Admin Protocol.
     * Inherits from ownership or verifies admin role in directory.
     */
    function isAdmin(tenantId) {
      return isSignedIn() && (
        isOwner(tenantId) ||
        (exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid)).data.role in ['owner', 'admin'])
      );
    }

    function isStaff(tenantId) {
      return isSignedIn() && (
        isAdmin(tenantId) ||
        exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid))
      );
    }

    // --- STRATEGIC DATA ACCESS ---

    // Master rule for all studio data subcollections (Inventory, Quotes, Ledger, etc.)
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isAdmin(tenantId);
      allow read: if isStaff(tenantId);
    }

    // Tenant Profile Access
    match /tenants/{tenantId} {
      allow get: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin(tenantId);
    }

    // Identity & Access Mapping
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /staffDirectory/{staffId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    // Public Terminal & Check-in Logic
    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if true;
    }
    
    // Explicit Public Quote Review
    match /tenants/{tenantId}/quotes/{quoteId} {
      allow get: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'declinedAt']);
    }
  }
}