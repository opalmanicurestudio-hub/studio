
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the legal owner of the tenant.
     * Uses a direct lookup on the tenant document.
     */
    function isTenantOwner(tenantId) {
      return isSignedIn() && get(/databases/$(database)/documents/tenants/$(tenantId)).data.userId == request.auth.uid;
    }

    // --- UNIVERSAL OWNER OVERRIDE ---
    // The "Simpler Way": If you own the tenant, you have total control over all its nested data.
    // This resolves evaluation crashes and "get-limit" issues for owners.
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isTenantOwner(tenantId);
    }

    // --- Specific Rule Adjustments for Performance & Access ---

    // Top-level tenant document access
    match /tenants/{tenantId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && request.query.where[0] == 'userId' && request.query.where[1] == '==' && request.query.where[2] == request.auth.uid;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Staff Directory (Lookup for roles)
    match /staffDirectory/{staffId} {
      allow get: if isSignedIn() && (request.auth.uid == staffId || isTenantOwner(resource.data.tenantId));
      allow write: if isSignedIn(); 
    }

    // Public Check-in Portal
    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if 
        (isSignedIn()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkInStatus', 'lateTimeMinutes', 'status']));
    }
  }
}
