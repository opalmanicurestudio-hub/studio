rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Identity Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Master Authority check. 
     * Prioritizes technical ownership (the UID that created the studio).
     */
    function isOwner(tenantId) {
      let tenantDoc = get(/databases/$(database)/documents/tenants/$(tenantId));
      return isSignedIn() && tenantDoc.data.userId == request.auth.uid;
    }

    /**
     * @description Role-based management check.
     * Inherits from ownership or checks the explicitly assigned role.
     */
    function isAdmin(tenantId) {
      return isSignedIn() && (
        isOwner(tenantId) ||
        (exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid)).data.role in ['owner', 'admin'])
      );
    }

    function isStaff(tenantId) {
      return isSignedIn() && (
        isAdmin(tenantId) ||
        exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid))
      );
    }

    // --- UNIVERSAL DATA PROTOCOL ---

    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isAdmin(tenantId);
      allow read: if isStaff(tenantId);
    }

    // Special case for public assets
    match /tenants/{tenantId} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    // Public Quote Access (For guest review and acceptance)
    match /tenants/{tenantId}/quotes/{quoteId} {
      allow get: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'declinedAt']);
    }

    // Identity & Directory
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /staffDirectory/{staffId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if 
        (isSignedIn()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkInStatus', 'lateTimeMinutes', 'status']));
    }
  }
}