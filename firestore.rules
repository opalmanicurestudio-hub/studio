rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the legal owner of the tenant.
     */
    function isTenantOwner(tenantId) {
      return isSignedIn() && get(/databases/$(database)/documents/tenants/$(tenantId)).data.userId == request.auth.uid;
    }

    /**
     * @description Checks if the user is a registered staff member.
     */
    function isStaff(tenantId) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)).data.tenantId == tenantId;
    }

    // --- SIMPLIFIED TOP-LEVEL ACCESS ---

    /**
     * UNIVERSAL OWNER/STAFF OVERRIDE
     * This simplified rule set grants full access to owners and staff 
     * for all sub-collections, avoiding complex "get" limit issues.
     */
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isTenantOwner(tenantId) || isStaff(tenantId);
    }

    // Top-level tenant document access
    match /tenants/{tenantId} {
      allow get: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow list: if isSignedIn() && request.query.where[0] == 'userId' && request.query.where[1] == '==' && request.query.where[2] == request.auth.uid;
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Staff Directory (Lookup for roles)
    match /staffDirectory/{staffId} {
      allow get: if isOwner(staffId);
      allow write: if isSignedIn(); // Allow registration during onboarding
    }

    // Public Check-in Portal
    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if 
        (isSignedIn()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkInStatus', 'lateTimeMinutes', 'status']));
    }
  }
}