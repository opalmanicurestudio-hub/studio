rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the technical owner of the tenant.
     * Checks the userId field on the tenant document directly for Jessica Marshall's UID parity.
     */
    function isOwner(tenantId) {
      return isSignedIn() && (
        get(/databases/$(database)/documents/tenants/$(tenantId)).data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)).data.role == 'owner')
      );
    }

    function isAdmin(tenantId) {
      return isSignedIn() && (
        isOwner(tenantId) ||
        (exists(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)).data.role == 'admin')
      );
    }

    // --- UNIVERSAL OWNER OVERRIDE ---
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isOwner(tenantId);
    }

    // --- Special Rules for Shared Access ---

    // Top-level tenant document access
    match /tenants/{tenantId} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    // Public Quote Portal Access
    match /tenants/{tenantId}/quotes/{quoteId} {
      allow get: if true; // Allows guests to view their proposal
    }

    // User profiles
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // Staff Directory (Safe Lookup)
    match /staffDirectory/{staffId} {
      allow get: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    // Public Check-in Portal
    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if 
        (isSignedIn()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkInStatus', 'lateTimeMinutes', 'status']));
    }
  }
}