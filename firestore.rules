
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(tenantId) {
      return isSignedIn() && request.auth.uid == get(/databases/$(database)/documents/tenants/$(tenantId)).data.userId;
    }

    function isStaff(tenantId) {
      return isSignedIn() && (
        isOwner(tenantId) ||
        exists(/databases/$(database)/documents/tenants/$(tenantId)/staff/$(request.auth.uid))
      );
    }

    // --- Tenant Root ---
    match /tenants/{tenantId} {
      allow get: if true; // Critical for public portals
      allow list: if isSignedIn();
      allow update: if isOwner(tenantId);
    }

    // --- Public Portals (Check-in & Concierge) ---
    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow update: if true;
    }

    match /tenants/{tenantId}/inventory/{itemId} {
      // Allow public to list refreshments for the concierge menu
      allow list, get: if true;
      // Only staff can update stock levels
      allow update: if isStaff(tenantId);
      // Admin/Owner full access
      allow write: if isStaff(tenantId);
    }

    match /tenants/{tenantId}/refreshmentRequests/{requestId} {
      allow create: if true; // Guests can request
      allow get: if true;
      allow list, update: if isStaff(tenantId);
    }

    match /tenants/{tenantId}/services/{serviceId} {
      allow read: if true;
    }

    match /tenants/{tenantId}/staff/{staffId} {
      allow read: if true;
    }

    match /tenants/{tenantId}/appointments/{appointmentId} {
      allow get: if true; // Allow guests to view their own booked session
      allow read, write: if isStaff(tenantId);
    }

    match /tenants/{tenantId}/clients/{clientId} {
      allow get: if true; // Allow guests to view their profile during check-in
      allow read, write: if isStaff(tenantId);
    }

    // --- Master Admin Access ---
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isStaff(tenantId);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}
