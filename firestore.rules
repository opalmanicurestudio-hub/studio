rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Core Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the user is the master owner of the tenant.
     * Prioritizes direct userId check on the tenant document for immediate authority.
     */
    function isOwner(tenantId) {
      let tenantDoc = get(/databases/$(database)/documents/tenants/$(tenantId));
      return isSignedIn() && (
        tenantDoc.data.userId == request.auth.uid ||
        (exists(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)).data.role == 'owner')
      );
    }

    function isAdmin(tenantId) {
      return isSignedIn() && (
        isOwner(tenantId) ||
        (exists(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)) && 
         (get(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)).data.role == 'admin' || 
          get(/databases/$(database)/documents/staffDirectory/$(request.auth.uid)).data.role == 'owner'))
      );
    }

    // --- UNIVERSAL OWNER OVERRIDE ---
    match /tenants/{tenantId}/{allSubcollections=**} {
      allow read, write: if isOwner(tenantId);
    }

    // --- Special Rules for Shared Access ---

    match /tenants/{tenantId} {
      allow get: if true;
      allow create: if isSignedIn();
    }

    // Public Quote Portal Access (Allows guests to view their proposal)
    match /tenants/{tenantId}/quotes/{quoteId} {
      allow get: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'acceptedAt', 'declinedAt']);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    match /staffDirectory/{staffId} {
      allow get: if isSignedIn();
      allow write: if isSignedIn(); 
    }

    match /appointmentCheckIns/{token} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if 
        (isSignedIn()) || 
        (request.auth == null && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['checkInStatus', 'lateTimeMinutes', 'status']));
    }
  }
}