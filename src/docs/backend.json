
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClarityFlow application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's last name."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant (business) within the multi-tenant application, owned by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the tenant."
        },
        "name": {
          "type": "string",
          "description": "Name of the tenant (business)."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this tenant."
        }
      },
      "required": [
        "id",
        "name",
        "userId"
      ]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Represents a service offered by a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "durationMinutes": {
          "type": "number"
        },
        "price": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "durationMinutes",
        "price"
      ]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product used or sold by a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "cost": {
          "type": "number"
        },
        "quantity": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "cost",
        "quantity"
      ]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Represents a client of a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        },
        "address": {
            "type": "object",
            "properties": {
                "street": { "type": "string" },
                "city": { "type": "string" },
                "state": { "type": "string" },
                "zip": { "type": "string" },
                "country": { "type": "string" }
            }
        },
        "emergencyContact": {
            "type": "object",
            "properties": {
                "name": { "type": "string" },
                "relationship": { "type": "string" },
                "phone": { "type": "string" }
            }
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName"
      ]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment booked with a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        },
        "serviceId": {
          "type": "string"
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "clientId",
        "serviceId",
        "startTime",
        "endTime"
      ]
    },
    "Bill": {
      "title": "Bill",
      "type": "object",
      "description": "A recurring bill or expense for a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "dueDay": {
          "type": "number"
        },
        "billingCycle": {
          "type": "string",
          "enum": ["monthly", "annually", "quarterly", "weekly"]
        },
        "context": {
          "type": "string",
          "enum": ["Business", "Personal"]
        },
        "category": {
          "type": "string"
        }
      },
      "required": ["id", "name", "amount", "dueDay", "billingCycle", "context", "category"]
    },
    "LifestyleProfile": {
      "title": "Lifestyle Profile",
      "type": "object",
      "description": "A financial profile representing a user's personal lifestyle costs.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "isActive"]
    },
    "BusinessProfile": {
      "title": "Business Profile",
      "type": "object",
      "description": "A financial profile representing a tenant's business operating costs.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "isActive"]
    },
    "ScheduleProfile": {
      "title": "Schedule Profile",
      "type": "object",
      "description": "A profile defining a tenant's work availability and schedule.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "isPublic": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "isActive"]
    },
    "Transaction": {
      "title": "Transaction",
      "type": "object",
      "description": "Represents a single financial transaction (income, expense, etc.) for a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "date": {
          "type": "string",
          "format": "date-time"
        },
        "description": {
          "type": "string"
        },
        "clientOrVendor": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["income", "expense", "reversal", "payment"]
        },
        "context": {
          "type": "string",
          "enum": ["Business", "Personal"]
        },
        "category": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "paymentMethod": {
          "type": "string",
          "description": "The method of payment used for the transaction."
        },
        "hasReceipt": {
          "type": "boolean"
        }
      },
      "required": ["id", "date", "description", "type", "context", "category", "amount", "paymentMethod"]
    },
    "StockCorrection": {
      "title": "Stock Correction",
      "type": "object",
      "description": "Represents a single atomic change to inventory stock levels.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string", "description": "The ID of the product being adjusted." },
        "date": { "type": "string", "format": "date-time" },
        "change": { "type": "number", "description": "The amount of change (e.g., -20 for 20ml used, 1 for 1 new container)." },
        "unit": { "type": "string", "description": "The unit of the change (e.g., 'ml', 'uses', 'container')." },
        "reason": { "type": "string", "description": "The reason for the correction (e.g., 'Appointment #123', 'Manual Count', 'Spoilage')." }
      },
      "required": ["id", "productId", "date", "change", "unit", "reason"]
    },
    "Quote": {
      "title": "Quote",
      "type": "object",
      "description": "Represents a quote or proposal for a client event.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "eventName": { "type": "string" },
        "eventDate": { "type": "string", "format": "date" },
        "eventLocation": { "type": "string" },
        "lineItems": {
          "type": "array",
          "items": { "type": "object" }
        },
        "travelExpenses": { "type": "number" },
        "projectFee": { "type": "number" },
        "notes": { "type": "string" },
        "totalHours": { "type": "number" },
        "status": { "type": "string", "enum": ["draft", "sent", "accepted", "declined", "booked"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["id", "clientId", "eventName", "status", "createdAt", "userId"]
    },
     "Event": {
      "title": "Event",
      "type": "object",
      "description": "Represents a calendar event, which could be a booked quote.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "notes": { "type": "string" },
        "quoteId": { "type": "string", "description": "The ID of the quote this event was booked from." }
      },
      "required": ["id", "title", "startTime", "endTime"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/tenants/{tenantId}": {
      "schema": {
        "$ref": "#/entities/Tenant"
      },
      "description": "Stores tenant (business) profiles. All business-specific data is nested under this."
    },
    "/tenants/{tenantId}/services/{serviceId}": {
      "schema": {
        "$ref": "#/entities/Service"
      },
      "description": "Services offered by a specific tenant."
    },
    "/tenants/{tenantId}/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Products sold or used by a specific tenant."
    },
    "/tenants/{tenantId}/clients/{clientId}": {
      "schema": {
        "$ref": "#/entities/Client"
      },
      "description": "Clients belonging to a specific tenant."
    },
    "/tenants/{tenantId}/appointments/{appointmentId}": {
      "schema": {
        "$ref": "#/entities/Appointment"
      },
      "description": "Appointments for a specific tenant."
    },
    "/tenants/{tenantId}/events/{eventId}": {
      "schema": {
        "$ref": "#/entities/Event"
      },
      "description": "Calendar events for a tenant, including booked quotes."
    },
    "/tenants/{tenantId}/quotes/{quoteId}": {
      "schema": {
        "$ref": "#/entities/Quote"
      },
      "description": "Quotes or proposals for a specific tenant."
    },
    "/tenants/{tenantId}/bills/{billId}": {
      "schema": {
        "$ref": "#/entities/Bill"
      },
      "description": "Recurring bills and expenses for a specific tenant."
    },
     "/tenants/{tenantId}/lifestyleProfiles/{profileId}": {
      "schema": {
        "$ref": "#/entities/LifestyleProfile"
      },
      "description": "Personal financial profiles for the user owning the tenant."
    },
    "/tenants/{tenantId}/businessProfiles/{profileId}": {
      "schema": {
        "$ref": "#/entities/BusinessProfile"
      },
      "description": "Business cost profiles for a specific tenant."
    },
    "/tenants/{tenantId}/scheduleProfiles/{profileId}": {
      "schema": {
        "$ref": "#/entities/ScheduleProfile"
      },
      "description": "Work schedule profiles for a specific tenant."
    },
    "/tenants/{tenantId}/transactions/{transactionId}": {
      "schema": {
        "$ref": "#/entities/Transaction"
      },
      "description": "Financial transaction log for a specific tenant."
    },
    "/tenants/{tenantId}/stockCorrections/{correctionId}": {
      "schema": {
        "$ref": "#/entities/StockCorrection"
      },
      "description": "An audit log of all inventory stock changes."
    }
  }
}
