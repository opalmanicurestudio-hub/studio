
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClarityFlow application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Represents a business tenant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive", "canceled"] },
        "subscriptionTier": { "type": "string", "enum": ["none", "solo", "studio", "enterprise"] },
        "tmhr": { "type": "number" },
        "cancellationFee": { "type": "number" },
        "cancellationWindowHours": { "type": "number" },
        "defaultCancellationMode": { "type": "string", "enum": ["matrix", "flat", "percentage"] },
        "tightSchedulingEnabled": { "type": "boolean" },
        "morningAnchorEnabled": { "type": "boolean" },
        "flashYieldEnabled": { "type": "boolean" },
        "bookingPageSettings": { "type": "object" },
        "kioskSettings": { "type": "object" }
      },
      "required": ["id", "name", "userId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "duration": { "type": "number" },
        "category": { "type": "string" },
        "cancellationFeeMode": { "type": "string", "enum": ["inherit", "matrix", "flat", "percentage"] },
        "cancellationFeeValue": { "type": "number" }
      },
      "required": ["id", "name", "price"]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "archived", "banned"] },
        "banMessage": { "type": "string" },
        "cancellationCount": { "type": "number", "default": 0 },
        "noShowCount": { "type": "number", "default": 0 },
        "rescheduleCount": { "type": "number", "default": 0 },
        "lifetimeValue": { "type": "number", "default": 0 },
        "outstandingBalance": { "type": "number", "default": 0 }
      },
      "required": ["id", "name"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/tenants/{tenantId}": {
      "schema": { "$ref": "#/backend/entities/Tenant" },
      "description": "Tenant business settings."
    },
    "/tenants/{tenantId}/services/{serviceId}": {
      "schema": { "$ref": "#/backend/entities/Service" },
      "description": "Studio treatments."
    },
    "/tenants/{tenantId}/clients/{clientId}": {
      "schema": { "$ref": "#/backend/entities/Client" },
      "description": "Guest records."
    }
  }
}
