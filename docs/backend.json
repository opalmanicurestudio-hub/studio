{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClarityFlow application.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user."
        },
        "email": {
          "type": "string",
          "description": "User's email address.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's last name."
        }
      },
      "required": [
        "id",
        "email"
      ]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Represents a tenant (business) within the multi-tenant application, owned by a user.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the tenant."
        },
        "name": {
          "type": "string",
          "description": "Name of the tenant (business)."
        },
        "userId": {
          "type": "string",
          "description": "The ID of the user who owns this tenant."
        }
      },
      "required": [
        "id",
        "name",
        "userId"
      ]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "description": "Represents a service offered by a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "durationMinutes": {
          "type": "number"
        },
        "price": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "durationMinutes",
        "price"
      ]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Represents a product used or sold by a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "cost": {
          "type": "number"
        },
        "quantity": {
          "type": "number"
        }
      },
      "required": [
        "id",
        "name",
        "cost",
        "quantity"
      ]
    },
    "Client": {
      "title": "Client",
      "type": "object",
      "description": "Represents a client of a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "firstName": {
          "type": "string"
        },
        "lastName": {
          "type": "string"
        },
        "email": {
          "type": "string",
          "format": "email"
        },
        "phone": {
          "type": "string"
        }
      },
      "required": [
        "id",
        "firstName",
        "lastName"
      ]
    },
    "Appointment": {
      "title": "Appointment",
      "type": "object",
      "description": "Represents an appointment booked with a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "clientId": {
          "type": "string"
        },
        "serviceId": {
          "type": "string"
        },
        "startTime": {
          "type": "string",
          "format": "date-time"
        },
        "endTime": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "clientId",
        "serviceId",
        "startTime",
        "endTime"
      ]
    },
    "Bill": {
      "title": "Bill",
      "type": "object",
      "description": "A recurring bill or expense for a tenant.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "amount": {
          "type": "number"
        },
        "dueDay": {
          "type": "number"
        },
        "billingCycle": {
          "type": "string",
          "enum": ["monthly", "annually", "quarterly", "weekly"]
        },
        "context": {
          "type": "string",
          "enum": ["Business", "Personal"]
        },
        "category": {
          "type": "string"
        }
      },
      "required": ["id", "name", "amount", "dueDay", "billingCycle", "context", "category"]
    },
    "LifestyleProfile": {
      "title": "Lifestyle Profile",
      "type": "object",
      "description": "A financial profile representing a user's personal lifestyle costs.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "isActive"]
    },
    "BusinessProfile": {
      "title": "Business Profile",
      "type": "object",
      "description": "A financial profile representing a tenant's business operating costs.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "isActive"]
    },
    "ScheduleProfile": {
      "title": "Schedule Profile",
      "type": "object",
      "description": "A profile defining a tenant's work availability and schedule.",
      "properties": {
        "id": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "isActive": {
          "type": "boolean"
        },
        "isPublic": {
          "type": "boolean"
        }
      },
      "required": ["id", "name", "isActive"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/tenants/{tenantId}": {
      "schema": {
        "$ref": "#/entities/Tenant"
      },
      "description": "Stores tenant (business) profiles. All business-specific data is nested under this."
    },
    "/tenants/{tenantId}/services/{serviceId}": {
      "schema": {
        "$ref": "#/entities/Service"
      },
      "description": "Services offered by a specific tenant."
    },
    "/tenants/{tenantId}/products/{productId}": {
      "schema": {
        "$ref": "#/entities/Product"
      },
      "description": "Products sold or used by a specific tenant."
    },
    "/tenants/{tenantId}/clients/{clientId}": {
      "schema": {
        "$ref": "#/entities/Client"
      },
      "description": "Clients belonging to a specific tenant."
    },
    "/tenants/{tenantId}/appointments/{appointmentId}": {
      "schema": {
        "$ref": "#/entities/Appointment"
      },
      "description": "Appointments for a specific tenant."
    },
    "/tenants/{tenantId}/bills/{billId}": {
      "schema": {
        "$ref": "#/entities/Bill"
      },
      "description": "Recurring bills and expenses for a specific tenant."
    },
     "/tenants/{tenantId}/lifestyleProfiles/{profileId}": {
      "schema": {
        "$ref": "#/entities/LifestyleProfile"
      },
      "description": "Personal financial profiles for the user owning the tenant."
    },
    "/tenants/{tenantId}/businessProfiles/{profileId}": {
      "schema": {
        "$ref": "#/entities/BusinessProfile"
      },
      "description": "Business cost profiles for a specific tenant."
    },
    "/tenants/{tenantId}/scheduleProfiles/{profileId}": {
      "schema": {
        "$ref": "#/entities/ScheduleProfile"
      },
      "description": "Work schedule profiles for a specific tenant."
    }
  }
}
