
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClarityFlow application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Represents a business tenant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive"] },
        "subscriptionTier": { "type": "string", "enum": ["none", "solo", "studio", "enterprise"] },
        "wifiNetwork": { "type": "string" },
        "wifiPassword": { "type": "string" },
        "refreshmentServiceEnabled": { "type": "boolean", "default": false },
        "complimentaryAmenityLimit": { "type": "number", "default": 0, "description": "Maximum number of free refreshments allowed per guest per session." },
        "bookingPageSettings": { "type": "object" },
        "kioskSettings": { "type": "object" }
      },
      "required": ["id", "name", "userId"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string", "description": "Public-facing description for the refreshment menu." },
        "type": { "type": "string", "enum": ["professional", "retail", "equipment", "overhead", "refreshment"] },
        "category": { "type": "string" },
        "totalStock": { "type": "number" },
        "costPerUnit": { "type": "number" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "name", "type", "totalStock"]
    },
    "RefreshmentRequest": {
      "title": "Refreshment Request",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "tenantId": { "type": "string" },
        "appointmentId": { "type": "string" },
        "clientId": { "type": "string" },
        "clientName": { "type": "string" },
        "itemId": { "type": "string" },
        "itemName": { "type": "string" },
        "quantity": { "type": "number", "default": 1 },
        "status": { "type": "string", "enum": ["pending", "delivered", "cancelled"] },
        "requestedAt": { "type": "string", "format": "date-time" },
        "deliveredAt": { "type": "string", "format": "date-time" },
        "deliveredBy": { "type": "string" },
        "stationName": { "type": "string", "description": "The name of the station or room where the guest is located." },
        "staffName": { "type": "string", "description": "The name of the service provider assigned to the guest." },
        "isRedemption": { "type": "boolean", "default": false, "description": "True if this request was a membership perk redemption." }
      },
      "required": ["id", "tenantId", "itemId", "status", "requestedAt"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/tenants/{tenantId}": {
      "schema": { "$ref": "#/backend/entities/Tenant" },
      "description": "Tenant business settings."
    },
    "/tenants/{tenantId}/inventory/{itemId}": {
      "schema": { "$ref": "#/backend/entities/InventoryItem" },
      "description": "Studio inventory including refreshments."
    },
    "/tenants/{tenantId}/refreshmentRequests/{requestId}": {
      "schema": { "$ref": "#/backend/entities/RefreshmentRequest" },
      "description": "Active concierge requests."
    },
    "/tenants/{tenantId}/appointments/{appointmentId}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Appointments."
    },
    "/appointmentCheckIns/{token}": {
      "schema": { "$ref": "#/backend/entities/Appointment" },
      "description": "Public check-in tokens."
    }
  }
}
