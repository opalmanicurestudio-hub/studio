
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the ClarityFlow application.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" }
      },
      "required": ["id", "email"]
    },
    "Tenant": {
      "title": "Tenant",
      "type": "object",
      "description": "Represents a business tenant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "userId": { "type": "string" },
        "subscriptionStatus": { "type": "string", "enum": ["active", "inactive"] },
        "subscriptionTier": { "type": "string", "enum": ["none", "solo", "studio", "enterprise"] },
        "wifiNetwork": { "type": "string" },
        "wifiPassword": { "type": "string" },
        "refreshmentServiceEnabled": { "type": "boolean", "default": false },
        "complimentaryAmenityLimit": { "type": "number", "default": 0 },
        "cancellationFee": { "type": "number" },
        "cancellationWindowHours": { "type": "number" },
        "defaultCancellationMode": { "type": "string", "enum": ["matrix", "flat"] },
        "tightSchedulingEnabled": { "type": "boolean", "default": false },
        "morningAnchorEnabled": { "type": "boolean", "default": false },
        "bookingPageSettings": { "type": "object" },
        "kioskSettings": { "type": "object" }
      },
      "required": ["id", "name", "userId"]
    },
    "Service": {
      "title": "Service",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "price": { "type": "number" },
        "cost": { "type": "number" },
        "duration": { "type": "number" },
        "category": { "type": "string" },
        "cancellationWindowHours": { "type": "number", "description": "Override for the cancellation notice window in hours." },
        "customCancellationFee": { "type": "number", "description": "Specific override fee for late cancellations of this service." }
      },
      "required": ["id", "name", "price"]
    },
    "InventoryItem": {
      "title": "Inventory Item",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["professional", "retail", "equipment", "overhead", "refreshment"] },
        "totalStock": { "type": "number" },
        "costPerUnit": { "type": "number" }
      },
      "required": ["id", "name", "type", "totalStock"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/backend/entities/User" },
      "description": "User profiles."
    },
    "/tenants/{tenantId}": {
      "schema": { "$ref": "#/backend/entities/Tenant" },
      "description": "Tenant business settings."
    },
    "/tenants/{tenantId}/services/{serviceId}": {
      "schema": { "$ref": "#/backend/entities/Service" },
      "description": "Studio treatments."
    }
  }
}
